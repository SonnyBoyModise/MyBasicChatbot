<!-- ============================================================
     MainWindow.xaml
     Main GUI window for the Cybersecurity Awareness Chatbot.
     Layout:
       - Left panel  : ASCII logo, user info card, memory panel
       - Right panel : Chat history (ScrollViewer), input bar, send button
     Dark cybersecurity theme with cyan accents.
     ============================================================ -->
<Window x:Class="MyBasicChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="рҹ”җ Cybersecurity Awareness Bot вҖ” South Africa"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <!-- Scroll bar style вҖ” thin dark scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="#161B22"/>
        </Style>
    </Window.Resources>

    <!-- в”Җв”Җ Root Grid: two columns (left panel + right chat) в”Җв”Җ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
             LEFT PANEL вҖ” Logo, user info, memory, quick tips
             в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
        <Border Grid.Column="0"
                Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="0,0,1,0">

            <DockPanel Margin="0">

                <!-- Logo / Header -->
                <Border DockPanel.Dock="Top"
                        Background="#0D1117"
                        Padding="16,18,16,14"
                        BorderBrush="#30363D"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <!-- ASCII-style logo rendered as styled text -->
                        <TextBlock Text="в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— "
                                   FontFamily="Consolas"
                                   FontSize="7"
                                   Foreground="#00D4FF"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—"
                                   FontFamily="Consolas"
                                   FontSize="7"
                                   Foreground="#00D4FF"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="в–Ҳв–Ҳв•‘      в•ҡв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ"
                                   FontFamily="Consolas"
                                   FontSize="7"
                                   Foreground="#00D4FF"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="в–Ҳв–Ҳв•‘      в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—"
                                   FontFamily="Consolas"
                                   FontSize="7"
                                   Foreground="#00AACC"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ"
                                   FontFamily="Consolas"
                                   FontSize="7"
                                   Foreground="#00AACC"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•қ "
                                   FontFamily="Consolas"
                                   FontSize="7"
                                   Foreground="#008899"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="рҹ”җ CYBER AWARENESS BOT"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#00D4FF"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,2"/>
                        <TextBlock Text="South Africa"
                                   FontSize="10"
                                   Foreground="#8B949E"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Quick Topic Buttons -->
                <Border DockPanel.Dock="Bottom"
                        Padding="14,12"
                        BorderBrush="#30363D"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="QUICK TOPICS"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#8B949E"
                                   Margin="0,0,0,8"
                                   FontFamily="Consolas"/>
                        <WrapPanel>
                            <Button Content="Phishing"    Tag="phishing"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,3,4,3" Padding="10,6"
                                    FontSize="11"
                                    Click="QuickTopic_Click"/>
                            <Button Content="Passwords"   Tag="password"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#3FB950"
                                    Margin="0,3,4,3" Padding="10,6"
                                    FontSize="11"
                                    Click="QuickTopic_Click"/>
                            <Button Content="Malware"     Tag="malware"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#F0C543" Foreground="#0D1117"
                                    Margin="0,3,4,3" Padding="10,6"
                                    FontSize="11"
                                    Click="QuickTopic_Click"/>
                            <Button Content="Scams"       Tag="scam"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#F85149"
                                    Margin="0,3,4,3" Padding="10,6"
                                    FontSize="11"
                                    Click="QuickTopic_Click"/>
                            <Button Content="Safe Browsing" Tag="safe browsing"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#8957E5"
                                    Margin="0,3,4,3" Padding="10,6"
                                    FontSize="11"
                                    Click="QuickTopic_Click"/>
                            <Button Content="SA Law"      Tag="cyber law"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#388BFD"
                                    Margin="0,3,4,3" Padding="10,6"
                                    FontSize="11"
                                    Click="QuickTopic_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- User Info + Memory Panel (fills remaining space) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,14,14,0">

                        <!-- User Info Card -->
                        <Border Background="#21262D"
                                CornerRadius="8"
                                Padding="14,12"
                                Margin="0,0,0,14"
                                BorderBrush="#30363D"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="рҹ‘Ө USER"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="#8B949E"
                                           FontFamily="Consolas"
                                           Margin="0,0,0,8"/>
                                <TextBlock x:Name="UserNameLabel"
                                           Text="Not set"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#E6EDF3"/>
                                <TextBlock x:Name="SentimentLabel"
                                           Text="рҹҳҠ Mood: Neutral"
                                           FontSize="11"
                                           Foreground="#8B949E"
                                           Margin="0,4,0,0"/>
                                <TextBlock x:Name="MessageCountLabel"
                                           Text="Messages: 0"
                                           FontSize="11"
                                           Foreground="#8B949E"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Memory Panel -->
                        <Border Background="#21262D"
                                CornerRadius="8"
                                Padding="14,12"
                                Margin="0,0,0,14"
                                BorderBrush="#30363D"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="рҹ§  MEMORY"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="#8B949E"
                                           FontFamily="Consolas"
                                           Margin="0,0,0,8"/>
                                <TextBlock x:Name="MemoryInterestLabel"
                                           Text="Interest: вҖ”"
                                           FontSize="11"
                                           Foreground="#E6EDF3"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="MemoryLastTopicLabel"
                                           Text="Last topic: вҖ”"
                                           FontSize="11"
                                           Foreground="#E6EDF3"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="MemoryConcernLabel"
                                           Text="Concern: вҖ”"
                                           FontSize="11"
                                           Foreground="#E6EDF3"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Status / Tip Box -->
                        <Border x:Name="TipBox"
                                Background="#162032"
                                CornerRadius="8"
                                Padding="14,12"
                                BorderBrush="#00D4FF"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="рҹ’Ў DID YOU KNOW?"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="#00D4FF"
                                           FontFamily="Consolas"
                                           Margin="0,0,0,6"/>
                                <TextBlock x:Name="TipLabel"
                                           Text="South Africa ranks among the top targeted countries for cybercrime in Africa."
                                           FontSize="11"
                                           Foreground="#8B949E"
                                           TextWrapping="Wrap"
                                           LineHeight="18"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
             RIGHT PANEL вҖ” Name entry OR chat interface
             в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
        <Grid Grid.Column="1">

            <!-- в”Җв”Җ Name Entry Screen (shown first) в”Җв”Җ -->
            <Border x:Name="NameEntryPanel"
                    Background="#0D1117"
                    Visibility="Visible">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="420">

                    <TextBlock Text="рҹ”җ"
                               FontSize="52"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Welcome to the"
                               FontSize="16"
                               Foreground="#8B949E"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Cybersecurity Awareness Bot"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#00D4FF"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,4,0,4"/>

                    <TextBlock Text="Helping South African citizens stay safe online."
                               FontSize="13"
                               Foreground="#8B949E"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,32"/>

                    <TextBlock Text="What is your name?"
                               FontSize="15"
                               Foreground="#E6EDF3"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <TextBox x:Name="NameInputBox"
                             Style="{StaticResource ChatInput}"
                             FontSize="16"
                             Height="46"
                             Margin="0,0,0,8"
                             KeyDown="NameInput_KeyDown"/>

                    <!-- Validation error message -->
                    <TextBlock x:Name="NameErrorLabel"
                               Text=""
                               Foreground="#F85149"
                               FontSize="12"
                               Margin="0,0,0,12"
                               Visibility="Collapsed"/>

                    <Button Content="Start Chatting  вҶ’"
                            Style="{StaticResource PrimaryButton}"
                            Height="46"
                            FontSize="15"
                            Click="StartChat_Click"/>

                </StackPanel>
            </Border>

            <!-- в”Җв”Җ Chat Interface (hidden until name is entered) в”Җв”Җ -->
            <Grid x:Name="ChatPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <!-- Chat header -->
                    <RowDefinition Height="56"/>
                    <!-- Chat messages -->
                    <RowDefinition Height="*"/>
                    <!-- Input area -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Chat Header Bar -->
                <Border Grid.Row="0"
                        Background="#161B22"
                        BorderBrush="#30363D"
                        BorderThickness="0,0,0,1"
                        Padding="16,0">
                    <DockPanel VerticalAlignment="Center">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Ellipse Width="10" Height="10"
                                     Fill="#3FB950"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChatHeaderLabel"
                                       Text="Chat вҖ” "
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#E6EDF3"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="рҹ”’ Secure Session"
                                   FontSize="11"
                                   Foreground="#8B949E"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </DockPanel>
                </Border>

                <!-- Chat Messages ScrollViewer -->
                <ScrollViewer Grid.Row="1"
                              x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,12">
                    <StackPanel x:Name="ChatMessagesPanel"
                                Margin="0,0,8,0"/>
                </ScrollViewer>

                <!-- Input Area -->
                <Border Grid.Row="2"
                        Background="#161B22"
                        BorderBrush="#30363D"
                        BorderThickness="0,1,0,0"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="MessageInputBox"
                                 Style="{StaticResource ChatInput}"
                                 Height="44"
                                 Margin="0,0,10,0"
                                 KeyDown="MessageInput_KeyDown"
                                 FontSize="14"/>

                        <Button Grid.Column="1"
                                Content="Send  вһӨ"
                                Style="{StaticResource PrimaryButton}"
                                Height="44"
                                Width="100"
                                Click="SendMessage_Click"/>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>
